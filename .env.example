# Unified env template for the chuhai workflow stack
# Fill only the sections you actually use.
# Do not commit real secrets.

# =========================================================
# Email Sync: /抓取邮件/email_sync
# Required if you use mailbox sync and thread parsing
# =========================================================
EMAIL_ACCOUNT=
EMAIL_AUTH_CODE=
# Optional: task-upload mail sync falls back to EMAIL_* by default.
# Set these only if task-upload mail sync should use a different mailbox.
TASK_UPLOAD_MAIL_ACCOUNT=
TASK_UPLOAD_MAIL_AUTH_CODE=
IMAP_HOST=imap.qq.com
IMAP_PORT=993
DATA_DIR=./data/email_sync

# Optional overrides for email_sync storage
DB_PATH=
RAW_DIR=

# Leave empty to auto-discover mail folders, or use comma-separated values
MAIL_FOLDERS=


# =========================================================
# Screening Backend: /筛号/backend
# Required if you use Apify scraping
# =========================================================
SCREENING_DATA_DIR=./data/screening
APIFY_TOKEN=
APIFY_API_TOKEN=
APIFY_BACKUP_TOKENS=
APIFY_FREE_TOKENS=
APIFY_POLL_INTERVAL_SECONDS=5
APIFY_REQUEST_TIMEOUT=60
APIFY_TRANSPORT_MAX_RETRIES=3
APIFY_TRANSPORT_RETRY_BACKOFF_SECONDS=1.5
APIFY_BALANCE_REFRESH_INTERVAL_SECONDS=300
APIFY_BALANCE_POLLER_ENABLED=1
APIFY_GUARD_TTL_SECONDS=1800
APIFY_BUDGET_SAFETY_MULTIPLIER=1.1
APIFY_BUDGET_BUFFER_USD=0.1
APIFY_TIKTOK_COST_PER_PROFILE_USD=0.0
APIFY_TIKTOK_COST_PER_RESULT_USD=0.004
APIFY_INSTAGRAM_COST_PER_PROFILE_USD=0.0026
APIFY_INSTAGRAM_COST_PER_RESULT_USD=0.0
APIFY_INSTAGRAM_ABOUT_ADDON_COST_PER_PROFILE_USD=0.007
APIFY_YOUTUBE_COST_PER_PROFILE_USD=0.0
APIFY_YOUTUBE_COST_PER_RESULT_USD=0.004

BACKEND_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
BACKEND_BIND_HOST=127.0.0.1
BACKEND_PORT=5001
BACKEND_DEBUG=0
BACKEND_USE_RELOADER=0

TIKTOK_BATCH_SIZE=20
INSTAGRAM_BATCH_SIZE=50
YOUTUBE_BATCH_SIZE=5


# =========================================================
# Visual Review: /筛号/backend vision providers
# Fill at least one provider if you use image/visual review
# =========================================================
VISION_REQUEST_TIMEOUT=60
VISION_MODEL=gpt-5.4
VISUAL_REVIEW_REQUEST_COVER_LIMIT=9
VISUAL_REVIEW_CANDIDATE_COVER_LIMIT_FLOOR=12
VISUAL_REVIEW_MAX_WORKERS=6
VISUAL_REVIEW_MAX_RETRIES=3
VISUAL_REVIEW_RETRY_BASE_DELAY_SECONDS=2
VISUAL_REVIEW_RETRY_MAX_DELAY_SECONDS=12
VISUAL_IMAGE_DOWNLOAD_MAX_RETRIES=3
VISUAL_IMAGE_CACHE_ENABLED=1
VISUAL_IMAGE_CACHE_DIR=
OPENAI_MAX_INFLIGHT_REQUESTS=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
OPENAI_WIRE_API=chat_completions
OPENAI_PROVIDER_NAME=
OPENAI_REASONING_EFFORT=
OPENAI_VISION_MODEL=
VISION_PROVIDER_PREFERENCE=

VISION_REELX_API_KEY=
VISION_REELX_BASE_URL=https://llmxapi.com/v1beta
VISION_REELX_BASE_URL_FALLBACKS=https://reelxai.com/v1beta,https://hk.llmxapi.com/v1beta,https://hk.reelxai.com/v1beta
VISION_REELX_MODEL=qwen-vl-max
VISION_REELX_FALLBACK_MODEL=gemini-3-flash-preview

VISION_QIANDAO_API_KEY=
VISION_QIANDAO_BASE_URL=https://api2.qiandao.mom/v1
VISION_QIANDAO_MODEL=gemini-2.5-pro-preview-p
VISION_QIANDAO_FALLBACK_MODEL=gemini-3-flash-preview-S
VISION_QIANDAO_MAX_TOKENS=900
VISION_QIANDAO_TEMPERATURE=0.2

VISION_MIMO_API_KEY=
VISION_MIMO_BASE_URL=https://api.xiaomimimo.com/v1
VISION_MIMO_MODEL=mimo-v2-omni
VISION_MIMO_MAX_COMPLETION_TOKENS=2048

VISION_QUAN2GO_API_KEY=
VISION_QUAN2GO_BASE_URL=https://capi.quan2go.com/v1
VISION_QUAN2GO_MODEL=

VISION_LEMONAPI_API_KEY=
VISION_LEMONAPI_BASE_URL=https://new.lemonapi.site/v1
VISION_LEMONAPI_MODEL=


# =========================================================
# Feishu Bridge: ./feishu_screening_bridge
# Required if you pull templates/tasks/files from Feishu
# =========================================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_OPEN_BASE_URL=https://open.feishu.cn/open-apis
TIMEOUT_SECONDS=30

# One of the following is usually required for file import
FEISHU_FILE_TOKEN=
FEISHU_FILE_URL=

# Used by bitable export / attachment download
FEISHU_SOURCE_URL=
EMPLOYEE_INFO_URL=
TASK_UPLOAD_URL=

PROJECT_CODE=
PRIMARY_CATEGORY=
OWNER_NAME=

# Compatibility-only: set this only when you intentionally run the legacy external email bridge
EMAIL_PROJECT_ROOT=
EMAIL_ENV_FILE=.env

DOWNLOAD_DIR=./downloads
DOWNLOAD_NAME=
DASHBOARD_OUTPUT=
EXPORT_OUTPUT=
EXPORT_FORMAT=json
ATTACHMENT_OUTPUT_DIR=./downloads/bitable_attachments
TASK_UPLOAD_DOWNLOAD_DIR=./downloads/task_upload_attachments

PROJECT_CODE_PREFIX=P-FSH-
DEFAULT_PRIMARY_CATEGORY=lifestyle
TASK_UPLOAD_CATEGORY_OVERRIDES=Tapo:smart_home,duet:lifestyle,MINISO:lifestyle

MANUAL_UPDATE_ENDPOINT_URL=http://127.0.0.1:8765/api/project-workbench/manual-update
UPLOAD_ENDPOINT_URL=http://127.0.0.1:8765/api/project-home/import-screening-workbook


# =========================================================
# External Email Project Optional Env
# Keep these only if you still depend on that external project explicitly
# =========================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_CONCURRENCY=3

# Legacy duplicate-review fallbacks. Prefer OPENAI_* above for new runs.
